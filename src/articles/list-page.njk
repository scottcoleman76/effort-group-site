permalink: "/articles/index.html"
eleventyExcludeFromCollections: true
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Articles | The Effort Group</title>
<meta name="description" content="Thinking on leadership, organizational strategy, and growth from the team at The Effort Group.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/shared.css">
</head>
<body>
<header class="site-header">
  <div class="wrap">
    <a class="brand" href="/">The Effort Group</a>
    <a class="back" href="/">&larr; Back to site</a>
  </div>
</header>
<main>
  <div class="wrap">
    <h1 class="page-title">Articles</h1>
    <p class="sub">Thinking on leadership, organizational strategy, and growth from our team.</p>

    <input type="text" id="search-box" placeholder="Search articles...">
    <div class="tag-filters" id="tag-filters">
      <button class="tag-filter-btn active" data-tag="all">All</button>
      {% for t in allTags %}<button class="tag-filter-btn" data-tag="{{ t }}">{{ t }}</button>{% endfor %}
    </div>

    <div id="article-list">
      {% for a in articles %}
      <a class="card article-card" href="/articles/{{ a.slug }}/"
         data-title="{{ a.title | lower }}" data-excerpt="{{ a.excerpt | lower }}"
         data-tags="{{ a.tags | join(',') | lower }}">
        <div class="meta">{{ a.author }} &middot; {{ a.date | dateStr }}
          {% if a.tags %} &middot; {% for t in a.tags %}{{ t }}{% if not loop.last %}, {% endif %}{% endfor %}{% endif %}
        </div>
        <h2>{{ a.title }}</h2>
        <p>{{ a.excerpt }}</p>
      </a>
      {% else %}
      <p class="empty">No articles published yet.</p>
      {% endfor %}
    </div>
    <p class="empty" id="no-results" style="display:none;">No articles match your search.</p>
  </div>
</main>

<script>
  const searchBox = document.getElementById('search-box');
  const tagButtons = document.querySelectorAll('.tag-filter-btn');
  const cards = document.querySelectorAll('.article-card');
  const noResults = document.getElementById('no-results');
  let activeTag = 'all';

  function applyFilters() {
    const q = searchBox.value.trim().toLowerCase();
    let visibleCount = 0;
    cards.forEach(card => {
      const matchesText = !q || card.dataset.title.includes(q) || card.dataset.excerpt.includes(q);
      const matchesTag = activeTag === 'all' || card.dataset.tags.split(',').includes(activeTag.toLowerCase());
      const show = matchesText && matchesTag;
      card.style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });
    noResults.style.display = visibleCount === 0 ? 'block' : 'none';
  }

  searchBox.addEventListener('input', applyFilters);
  tagButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      tagButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeTag = btn.dataset.tag;
      applyFilters();
    });
  });
</script>
</body>
</html>
